{
  "name": "@server-monitor/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/generate-build-info.mjs",
    "dev": "nest start --watch",
    "prebuild": "node ../../scripts/generate-build-info.mjs",
    "build": "nest build && cp build-info.json dist/",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/throttler": "^6.2.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.4.0",
    "@server-monitor/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.2.2"
  }
}
