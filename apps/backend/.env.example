PORT=3300
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=server_monitor

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Agent authentication (required in production)
AGENT_API_KEY=your-agent-api-key

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=generate-a-random-256-bit-secret

# TimescaleDB: auto-drop metric snapshots older than N days
METRICS_RETENTION_DAYS=7

# Allow open user registration (default: false)
ALLOW_REGISTRATION=false

# Notifications (optional)
NOTIFICATION_DISCORD_WEBHOOK=
