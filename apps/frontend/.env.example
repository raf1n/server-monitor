# Environment variables for frontend development
VITE_ENV=development
# Backend REST API URL — set this to point to your backend
# Leave empty to use same-origin (/api/ prefix, e.g. behind nginx)
VITE_API_URL=http://localhost:3300

# Backend Socket.IO URL — set this to point to your backend WebSocket
# Leave empty to use same-origin (/socket.io/, e.g. behind nginx)
VITE_SOCKET_URL=http://localhost:3300
