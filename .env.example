# ─── Required (app will fail to start without these) ───

# Generate with: openssl rand -hex 64
JWT_SECRET=

# Shared secret that agents send as x-api-key header
AGENT_API_KEY=

# Admin panel password (username defaults to "admin")
ADMIN_PASSWORD=

# Password for Redis
REDIS_PASSWORD=

# Password for PostgreSQL
DB_PASSWORD=

# ─── Optional ───

# Set to "true" on first deploy to auto-create tables, then remove
# DB_SYNCHRONIZE=false

# Frontend origin for CORS
CORS_ORIGIN=https://monitor.example.com

# Public backend base URL used by the agent installer
PUBLIC_BASE_URL=https://monitor.example.com

# Frontend environment (development/production)
# VITE_ENV=production

# How long to keep metric snapshots (days)
METRICS_RETENTION_DAYS=7

# Allow open user registration (default: false, admin-only)
# ALLOW_REGISTRATION=false

# Notification channels (leave empty to disable)
NOTIFICATION_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# WEBHOOK_URL=https://hooks.example.com/...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# NOTIFICATION_EMAIL=alerts@example.com
