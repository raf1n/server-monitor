# Required — generate with: openssl rand -hex 64
JWT_SECRET=

# Required — shared secret that agents send as x-api-key header
AGENT_API_KEY=

# Required — admin panel password (username defaults to "admin")
ADMIN_PASSWORD=

# Frontend origin for CORS (your VPS domain)
# CORS_ORIGIN=https://monitor.example.com

# How long to keep metric snapshots (days)
# METRICS_RETENTION_DAYS=7

# Allow open user registration (default: false, admin-only)
# ALLOW_REGISTRATION=false
