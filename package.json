{
  "name": "server-monitor",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "esbuild",
      "msgpackr-extract"
    ],
    "ignoredBuiltDependencies": [
      "bcrypt"
    ],
    "overrides": {
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "webpack@>=5.49.0 <=5.104.0": ">=5.104.1",
      "webpack@>=5.49.0 <5.104.0": ">=5.104.0",
      "multer@<2.1.0": ">=2.1.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "multer@<2.1.1": ">=2.1.1",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "@nestjs/core@<=11.1.17": ">=11.1.18",
      "uuid@<11.1.1": ">=11.1.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "tmp@<0.2.6": ">=0.2.6",
      "multer@>=1.0.0 <2.2.0": ">=2.2.0",
      "multer@>=2.0.0-alpha.1 <2.2.0": ">=2.2.0",
      "cookie@<0.7.3": ">=0.7.3"
    }
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @server-monitor/frontend dev",
    "dev:backend": "pnpm --filter @server-monitor/backend dev",
    "dev:agent": "pnpm --filter @server-monitor/agent dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @server-monitor/frontend build",
    "build:backend": "pnpm --filter @server-monitor/backend build",
    "build:shared": "pnpm --filter @server-monitor/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:stop": "docker compose -f docker-compose.prod.yml stop",
    "docker:prod:rebuild": "VITE_API_URL= VITE_SOCKET_URL= pnpm --filter @server-monitor/frontend build && docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "deploy": "bash deploy.sh"
  }
}
