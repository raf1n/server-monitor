{
  "name": "server-monitor",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "esbuild",
      "msgpackr-extract"
    ],
    "ignoredBuiltDependencies": [
      "bcrypt"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @server-monitor/frontend dev",
    "dev:backend": "pnpm --filter @server-monitor/backend dev",
    "dev:agent": "pnpm --filter @server-monitor/agent dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @server-monitor/frontend build",
    "build:backend": "pnpm --filter @server-monitor/backend build",
    "build:shared": "pnpm --filter @server-monitor/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:rebuild": "VITE_API_URL= VITE_SOCKET_URL= pnpm --filter @server-monitor/frontend build && docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "deploy": "bash deploy.sh"
  }
}
